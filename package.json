{
	"name": "okasi.me",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"postinstall": "simple-git-hooks",
		"format": "biome format --write .",
		"lint": "biome check . --error-on-warnings",
		"typecheck": "tsc --noEmit",
		"test:e2e": "playwright test",
		"check": "npm run lint && npm run typecheck && npm run build && npm run test:e2e"
	},
	"dependencies": {
		"fumadocs-core": "^16.11.5",
		"fumadocs-mdx": "^15.2.0",
		"fumadocs-ui": "^16.11.5",
		"next": "^16.2.10",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.4",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/postcss": "^4.3.2",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"lint-staged": "^17.0.8",
		"simple-git-hooks": "^2.13.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^5.9.3"
	},
	"overrides": {
		"next": {
			"postcss": "8.5.20"
		}
	},
	"lint-staged": {
		"*.{js,ts,tsx,css,json,md,mdx}": "biome check --write --no-errors-on-unmatched"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	}
}
